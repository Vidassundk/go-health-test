{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "paths": {
      "@components": ["./components/index.ts"],
      "@components/*": ["./components/*"],
      "@icons": ["./components/icons/index.ts"],
      "@icons/*": ["./components/icons/*"],
      "@/*": ["./*"]
    }
  },
  "include": ["**/*.ts", "**/*.tsx", ".expo/types/**/*.ts", "expo-env.d.ts"]
}
